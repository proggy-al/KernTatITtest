{
  "Web": {
    "$schema": "app_settings_schemas/app_web_settings_schema.json#/definitions/Web",
    "Authorization": {
      "Enable": false
    },
    "CorsPolicy": {
      "Enable": true,
      "AllowAnyHeader": true,
      "AllowAnyMethod": true,
      "AllowAnyOrigin": true,
      "AllowCredentials": false
    },
    "ForwardedHeaders": {
      "Enable": true,
      "ForwardedHeaders": [ "All" ]
    },
    "PathBase": {
      "Enable": false
    }
  },

  "RestApi": {
    "$schema": "app_settings_schemas/app_web_restapi_settings_schema.json#/definitions/RestApi",
    "Controller": {
      "Enable": true,
      "SerializationNamingStrategy": "SnakeCase",
      "QueryParameterToSnakeCase": true
    },
    "OpenApi": {
      "Enable": true,
      "Info": {
        "Title": "KernCatalog.Api.App",
        "Description": "Каталог керна.",
        "Version": "1",
        "DocName": ""
      },
      "Contact": {
        "Name": "ООО \"ТатИТнефть\"",
        "Url": "https://tatitneft.ru",
        "Email": "info@tatitneft.ru"
      },
      "Versioning": true
    },
    "ApiVersioning": {
      "Enable": true,
      "ReportApiVersions": true,
      "ApiVersionReaderTypes": {
        "UrlSegment": true
      },
      "ApiExplorer": {
        "Enable": true,
        "GroupNameFormat": "'v'VVV",
        "SubstituteApiVersionInUrl": true
      }
    },
    "DisableSwaggerCache": false
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
