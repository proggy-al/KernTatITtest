{
    "$schema": "http://json-schema.org/draft-07/schema",
    "definitions": {
        "Provider": {
            "type": "object",
            "title": "Настройки провайдера данных.",
            "description": "Настройки необходимого провайдера данных.",
            "properties": {
                "Type": {
                    "enum": [
                        "PostgreSQL",
                        "ClickHouse"
                    ],
                    "title": "Тип провайдера.",
                    "description": "Тип провайдера данных, список ограничен."
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "Type": {
                                "const": "PostgreSQL"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "Settings": {
                                "type": "object",
                                "title": "Настройки.",
                                "description": "Настройки.",
                                "properties": {
                                    "ConnectionString": {
                                        "type": "string",
                                        "title": "Строка соединения.",
                                        "description": "Строка соединения."
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "Type": {
                                "const": "ClickHouse"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "Settings": {
                                "type": "object",
                                "title": "Настройки.",
                                "description": "Настройки.",
                                "properties": {
                                    "Connection": {
                                        "type": "string",
                                        "title": "Строка соединения.",
                                        "description": "Строка соединения."
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        },
        "Model": {
            "type": "object",
            "title": "Модель БД.",
            "description": "Задаются настройки и фильтрация объектов БД.",
            "properties": {
                "Tables": {
                    "type": "array",
                    "title": "Набор фильтров для таблиц.",
                    "description": "Набор фильтров для таблиц.",
                    "items": [
                        {
                            "type": "object",
                            "description": "Фильтр для таблицы.",
                            "properties": {
                                "Schema": {
                                    "type": [
                                        "string",
                                        "null"
                                    ],
                                    "title": "Схема БД",
                                    "description": "Схема БД в которой расположены таблицы."
                                },
                                "Name": {
                                    "type": "string",
                                    "description": "Фильтр по имени таблицы."
                                },
                                "Fields": {
                                    "type": "object",
                                    "description": "Поля таблицы.",
                                    "properties": {
                                        "Include": {
                                            "type": "array",
                                            "description": "Спиоск имен для включения.",
                                            "items": [
                                                {
                                                    "type": "string"
                                                }
                                            ]
                                        },
                                        "Exclude": {
                                            "type": "array",
                                            "description": "Спиоск имен для исключения.",
                                            "items": [
                                                {
                                                    "type": "string"
                                                }
                                            ]
                                        }
                                    }
                                }
                            },
                            "additionalProperties": false
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "CodeGen": {
            "type": "object",
            "title": "Генерация кода C#.",
            "description": "Настройки генерации кода C#.",
            "properties": {
                "Type": {
                    "$ref": "code_gen.schema.json#/definitions/CodeGenType",
                    "title": "Опции генерации типа.",
                    "description": "Опции генерации типа."
                },
                "Namespace": {
                    "type": "string",
                    "title": "Пространство имен в коде C# для сущности.",
                    "description": "Пространство имен в коде C# для сущности. Допускаются макросы: {EntityName}, {TypeName}, {TableSchema}."
                },
                "FileNamePattern": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "title": "Шаблон имени выходного генерируемого файла для сущности.",
                    "description": "Шаблон имени выходного файла для сущности. Допускаются макросы: {EntityName}, {TypeName}, {Namespace}, {TableSchema}.",
                    "default": "{TypeName}.gen.cs"
                },
                "ManualFileNamePattern": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "title": "Шаблон имени выходного ручного файла для сущности.",
                    "description": "Шаблон имени выходного файла для сущности. Допускаются макросы: {EntityName}, {TypeName}, {Namespace}, {TableSchema}.",
                    "default": "{TypeName}.cs"
                },
                "PkPropNotNull": {
                    "type": "boolean",
                    "description": "Признак обязательности значения свойства для первичного ключа.",
                    "default": true
                },
                "AncestorsAuto": {
                    "type": "boolean",
                    "description": "Признак автоматического определения предков.",
                    "default": true
                },
                "Ancestors": {
                    "type": "array",
                    "description": "Список предков.",
                    "items": [
                        {
                            "type": "string"
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "CodeGenAll": {
            "type": "object",
            "title": "Генерация кода C#.",
            "description": "Настройки генерации кода C#.",
            "properties": {
                "Entity": {
                    "$ref": "#/definitions/CodeGen"
                }
            },
            "additionalProperties": false
        }
    },
    "type": "object",
    "properties": {
        "OutPath": {
            "type": "string",
            "description": "Путь для сгенерированных файлов."
        },
        "Provider": {
            "$ref": "#/definitions/Provider"
        },
        "Model": {
            "$ref": "#/definitions/Model"
        },
        "CodeGen": {
            "$ref": "#/definitions/CodeGenAll"
        }
    }
}